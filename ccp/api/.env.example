# ccp-api — deploy env template. Copy to .env and fill in, or export these in
# your process manager / container. See README.md "Environment variables" for detail.
# TLS is terminated by an EXTERNAL reverse proxy; this process speaks HTTP behind it.

# Core runtime
NODE_ENV=production
PORT=8801

# Durable store (default FileStore). Point DATA_DIR at a persistent volume.
# CCP_STORE=memory        # NOT for production — refused by the preflight
CCP_DATA_DIR=/var/lib/ccp
# CCP_DATA_FILE=/var/lib/ccp/ccp.json   # explicit override of the full path

# First boot only — seeds one admin Lead + prints a one-time password. Refused once
# a data file exists. Remove for all subsequent starts.
# CCP_BOOTSTRAP=1

# TOTP secret cipher key (REQUIRED in production). Stable, high-entropy; rotating it
# invalidates enrolled second factors.
CCP_TOTP_KEY=change-me-to-a-long-random-value

# Session cookie posture. Secure defaults ON in production; do not disable behind TLS.
# CCP_SECURE_COOKIES=true
# CCP_COOKIE_SAMESITE=Lax   # Lax | Strict | None. Cross-origin SPA needs None (+Secure).

# Credentialed CORS: exact browser origin(s) allowed to authenticate (comma-separated).
# REQUIRED in production unless CCP_SAME_ORIGIN=1.
CCP_CORS_ORIGIN=https://ccp.example.com
# CCP_SAME_ORIGIN=1        # set instead of CORS origin if the SPA is served same-origin
