{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@app-lib/*": ["../app/src/lib/*"],
      "@/*": ["../app/src/*"]
    }
  },
  "include": ["src", "test", "scripts"]
}
