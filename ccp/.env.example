# =============================================================================
# ccp — deployment configuration for docker compose.
#   cp .env.example .env   then edit the values below   then: docker compose up -d --build
#
# Legend for each knob:
#   [SECRET]   you generate/inject — NEVER commit a real value
#   [OPERATOR] you set to your environment's real value
#   [DEFAULT]  a sane default; override only if you know why
#
# TLS is terminated by your EXTERNAL reverse proxy (see docker-compose.yml header).
# The placeholders below are NOT usable values — replace every [SECRET]/[OPERATOR].
# =============================================================================

# ── Public URL: flips the SPA into REAL mode ─────────────────────────────────
# [OPERATOR] The api's PUBLIC base URL, as the BROWSER reaches it THROUGH your TLS
# proxy. Baked into the SPA at build time — this is what turns the app from the
# demo/mock build into the REAL authoritative client. Leaving it empty ships the DEMO.
#   Same-origin topology (A, recommended):  https://ccp.example.com/api
#   Split-origin topology (B):               https://api.ccp.example.com
VITE_API_BASE=https://ccp.example.com/api

# ── Browser origin + cookie posture (choose ONE topology) ────────────────────
# Topology A — SAME-ORIGIN: the proxy serves the SPA and routes /api/* to the api
# on the SAME public host. No cross-site CORS; acknowledge it so the prod preflight
# is satisfied:
CCP_SAME_ORIGIN=1
CCP_CORS_ORIGIN=
CCP_COOKIE_SAMESITE=Lax

# Topology B — SPLIT-ORIGIN: the api is on its OWN host. Comment out the three A
# lines above and use these instead — [OPERATOR] set to the SPA's public origin:
# CCP_SAME_ORIGIN=
# CCP_CORS_ORIGIN=https://ccp.example.com
# CCP_COOKIE_SAMESITE=None

# [DEFAULT] Secure cookies ON. Do NOT disable behind TLS — the production preflight
# refuses to boot if this is off in production.
CCP_SECURE_COOKIES=1

# ── SECRET: TOTP secret-cipher key ───────────────────────────────────────────
# [SECRET] AES-256-GCM key for enrolled second factors. REQUIRED. Stable +
# high-entropy; rotating it invalidates every enrolled 2FA. Generate one with:
#     openssl rand -base64 48
# Paste the output below (this placeholder is deliberately NOT a usable key):
CCP_TOTP_KEY=REPLACE_ME__run: openssl rand -base64 48

# ── Instance identity (ADR-0023) — settable name, generic if left blank ──────
# [OPERATOR] The instance's displayed name — shown on the sign-in screen, the
# app header, and everywhere else the product names itself. Baked into the SPA
# build (VITE_INSTANCE_NAME, below) AND seeded into the server's runtime store
# during the SAME first boot (CCP_BOOTSTRAP=1) — one answer, two layers, so
# they agree from day one. Empty ⇒ the generic default "Cloud Control Plane" —
# a perfectly valid, neutral identity; renaming later needs no rebuild (Admin →
# Settings, or the first-run identity card), only this knob is for INSTALL time.
CCP_INSTANCE_NAME=
# [OPERATOR] Optional one-line tagline alongside the name. Empty is fine.
CCP_INSTANCE_TAGLINE=

# ── First boot only ──────────────────────────────────────────────────────────
# [OPERATOR] Set to 1 for the VERY FIRST `docker compose up` ONLY. It seeds one
# admin and prints a one-time password to the api logs, then you MUST set it back
# to empty. It is refused (the container exits 1) once the store exists, so a
# redeploy never reseeds over the live audit chain. See docs/go-live.md → "First boot".
CCP_BOOTSTRAP=

# ── Ports (published on 127.0.0.1 for a same-host reverse proxy) ──────────────
# [DEFAULT] api HTTP port behind the proxy (container-internal + published loopback).
PORT=8801
# [DEFAULT] app (SPA) static-server port published on loopback for the proxy.
APP_PORT=8800

# ── Rarely changed ───────────────────────────────────────────────────────────
# The durable store path INSIDE the api container is fixed at /var/lib/ccp and
# backed by a BIND MOUNT of /data/ccp/store (docker-compose.yml) — created and
# chowned by `scripts/setup.sh data`. To relocate it you must edit BOTH the bind
# mount and CCP_DATA_DIR there together.
# CCP_STORE is intentionally NOT set: the durable FileStore is the prod default;
# CCP_STORE=memory is refused by the preflight.

# ── CI runner (opt-in — profile: runner) ──────────────────────────────────────
# [DEFAULT] Uncomment to make a bare `docker compose up -d --build` also bring up
# the self-hosted CI runner — the sticky opt-in, which also lets self-update.sh
# rebuild it on code updates. Equivalent to always passing `--profile runner`.
# COMPOSE_PROFILES=runner

# [OPERATOR] The repo this runner registers against, e.g. https://github.com/<owner>/<repo>.
# Only needed the first time the runner container starts — see docs/go-live.md → "CI runner".
RUNNER_REPO_URL=

# [DEFAULT] Label(s) the runner advertises. Workflows opt in to it via
# `runs-on: ${{ vars.CI_RUNNER || 'ubuntu-latest' }}` + repo variable CI_RUNNER=ccp.
RUNNER_LABELS=ccp

# RUNNER_TOKEN is intentionally NOT set here: it is a short-lived registration
# token, passed ONCE on the shell and NEVER stored in this file:
#     gh api -X POST repos/<owner>/<repo>/actions/runners/registration-token --jq .token
#     RUNNER_TOKEN=<token> docker compose --profile runner up -d --build runner

# ── Armed overlay (opt-in — docker-compose.armed.yml) ─────────────────────────
# [OPERATOR] Only needed when arming CCP_BUNDLE_GATE_CMD / CCP_DRIFT_GEN_CMD
# (see api/README.md) through the docker-compose.armed.yml overlay, which grants
# the api container the docker socket. Set it to the socket's host GID:
#     stat -c %g /var/run/docker.sock
# CCP_DOCKER_GID=
