# Cloud Control Plane — environment configuration example.
# Copy to `.env` and adjust. All client-exposed vars MUST be prefixed VITE_.
# Note: src/config.ts holds the canonical defaults; these override at build time.

# GitHub target for the generated Terraform PRs (personal repo today).
VITE_GITHUB_OWNER=example-org
VITE_GITHUB_REPO=example-estate

# Optional backend API base. Leave unset to use the bundled mock API client.
VITE_API_BASE=

# There is deliberately NO AI/LLM configuration: Cloud Control Plane is deterministic and
# fully functional with no model and no network (see docs/adr/0007-gerbang-no-ai.md).
