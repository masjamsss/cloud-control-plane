{
  "name": "ccp-app",
  "private": true,
  "license": "Apache-2.0",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.scripts.json",
    "lint": "eslint . --ext .ts,.tsx",
    "contrast": "node scripts/check-contrast.mjs",
    "help:check": "python3 scripts/list-missing-help.py",
    "format:check": "prettier --check src",
    "test": "vitest run",
    "gen:provider-catalog": "vite-node scripts/gen-provider-catalog.ts",
    "verify:safety": "vite-node scripts/verify-manifest-safety.ts && vite-node scripts/verify-source-genericity.ts"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-popover": "^1.1.19",
    "@tanstack/react-virtual": "^3.14.5",
    "cmdk": "^1.1.1",
    "js-yaml": "^4.1.0",
    "qrcode.react": "4.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^6.26.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.3.3",
    "typescript": "^5.4.5",
    "vite": "^5.4.8",
    "vitest": "^1.6.0"
  }
}
