{
  "service": "iam",
  "scope": "estate",
  "resourceTypes": ["aws_iam_role", "aws_iam_role_policy_attachment"],
  "summary": "S2 fixture — mirrors the real iam-attach-managed-policy op that appended a policy_attachment{} block into aws_iam_role (a nonexistent nested block; managed attachments are the separate aws_iam_role_policy_attachment RESOURCE).",
  "operations": [
    {
      "id": "iam-attach-managed-policy",
      "service": "iam",
      "macd": "Add",
      "codemodOp": "append_block",
      "title": "Attach a managed policy to a role",
      "target": { "resourceType": "aws_iam_role", "block": "policy_attachment" },
      "params": [
        {
          "name": "role",
          "label": "Role",
          "type": "string",
          "source": "inventory",
          "enumSource": "inventory://aws_iam_role/address",
          "required": true
        },
        {
          "name": "policy_arn",
          "label": "Managed policy",
          "type": "string",
          "source": "allowlist",
          "required": true,
          "bounds": { "allowlist": ["arn:aws:iam::aws:policy/ReadOnlyAccess"] }
        }
      ],
      "riskFloor": "MEDIUM",
      "exposure": "l1_with_guardrails",
      "forcesReplace": false,
      "terraformCapability": "+ create (policy attachment)"
    }
  ]
}
