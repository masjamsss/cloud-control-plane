  "manual": [
    {
      "types": ["aws_lb_listener", "aws_lb_listener_rule"],
      "why": "need one describe-listeners / describe-rules call PER load balancer / listener — not a single list",
      "how": "aws elbv2 describe-listeners --load-balancer-arn <arn>; then describe-rules --listener-arn <arn>; import ids are the ARNs (see importer/prod/imports.tf aws_lb_listener / aws_lb_listener_rule blocks)",
      "arnHints": ["elasticloadbalancing"]
    },
    {
