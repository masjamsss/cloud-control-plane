    {
      "types": ["aws_lambda_event_source_mapping", "aws_lambda_permission"],
      "why": "per-function listings / policy reads",
      "how": "list-event-source-mappings (UUID id); permissions from get-policy statement ids",
      "arnHints": ["lambda"]
    },
    {
      "types": [
        "aws_sagemaker_domain",
        "aws_sagemaker_user_profile",
        "aws_sagemaker_space",
        "aws_sagemaker_pipeline"
      ],
      "why": "estate-specific ML stack; list calls exist but attribute alignment needed hand-work in prod",
      "how": "aws sagemaker list-domains / list-user-profiles / list-spaces / list-pipelines",
      "arnHints": ["sagemaker"]
    },
    {
      "types": [
        "aws_wafv2_web_acl",
        "aws_cloudfront_origin_access_control",
        "aws_config_configuration_recorder",
        "aws_config_delivery_channel",
        "aws_dlm_lifecycle_policy",
        "aws_licensemanager_license_configuration",
        "aws_ssm_association",
        "aws_ssm_document",
        "aws_default_network_acl",
        "aws_vpc_dhcp_options_association",
        "aws_ec2_instance_connect_endpoint"
      ],
      "why": "long tail the prod import handled by hand (composite ids, scoped listings, or defaults adopted rather than listed)",
      "how": "see the matching blocks in importer/prod/imports.tf for each id shape; add a types entry here once a clean single list call is identified",
      "arnHints": ["wafv2", "cloudfront", "dlm", "ssm", "ec2"]
    }
  ]
}
