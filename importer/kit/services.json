        "aws_s3_bucket_lifecycle_configuration",
        "aws_s3_bucket_ownership_controls",
        "aws_s3_bucket_cors_configuration"
      ],
      "why": "per-bucket get calls; blind generation per bucket over-imports configs that do not exist",
      "how": "per bucket: aws s3api get-bucket-versioning/-encryption/-public-access-block/... ; import id = bucket name (importer/prod/imports.tf convention)",
      "arnHints": []
    },
    {
