      ],
      "why": "per-principal list calls (list-role-policies, list-attached-role-policies, ...)",
      "how": "ids are '<principal>:<policy-name>' for inline and '<principal>/<policy-arn>' for attachments (verified against importer/prod/imports.tf)",
      "arnHints": []
    },
    {
      "types": ["aws_cloudwatch_event_target"],
