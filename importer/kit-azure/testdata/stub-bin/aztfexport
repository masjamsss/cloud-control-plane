#!/usr/bin/env bash
# Stub `aztfexport` for run-aztfexport.sh tests — no Azure, no real aztfexport. Replays a
# committed mapping file and/or writes a trivial main.tf into --output-dir. Env-driven:
#   STUB_MAPPING_FILE  file copied as aztfexportResourceMapping.json (default: {})
#   STUB_WRITE_STATE   if "1", ALSO writes a terraform.tfstate — used ONLY to prove that
#                      run-aztfexport.sh's read-only tripwire refuses when state appears.
set -u

out=""
prev=""
for a in "$@"; do
  [ "$prev" = "--output-dir" ] && out="$a"
  prev="$a"
done
[ -n "$out" ] || { echo "stub aztfexport: no --output-dir given" >&2; exit 1; }
mkdir -p "$out"

for a in "$@"; do
  if [ "$a" = "--generate-mapping-file" ]; then
    if [ -n "${STUB_MAPPING_FILE:-}" ] && [ -f "${STUB_MAPPING_FILE}" ]; then
      cp "${STUB_MAPPING_FILE}" "$out/aztfexportResourceMapping.json"
    else
      echo '{}' > "$out/aztfexportResourceMapping.json"
    fi
  fi
done

# always emit trivial HCL bodies (never state)
echo "# generated by stub aztfexport (test fixture)" > "$out/main.tf"

# the deliberate misbehavior the tripwire must catch
[ "${STUB_WRITE_STATE:-}" = "1" ] && echo '{}' > "$out/terraform.tfstate"

exit 0
