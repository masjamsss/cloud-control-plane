{
  "version": 1,
  "doctrine": "Any changed attribute matching this list makes the drift SECURITY-POSTURE class: never silently adopted, default disposition revert-in-AWS by a human, adopting requires explicit owner sign-off recorded on the drift issue. Matching: fnmatch (case-sensitive) against the normalized attribute path (indices stripped), its top-level attribute, and its leaf segment. Curate here, not in classify.py — the classifier only reads this file.",
  "known_gap": "Tags are deliberately NOT watchlisted (it would kill the tag-based adopt flow). If IAM policies ever condition on aws:ResourceTag/aws:PrincipalTag (ABAC), tag drift becomes security drift — operator judgement per the runbook, the classifier cannot see policy semantics.",
  "resource_types": {
    "aws_security_group": {
      "attributes": ["*"],
      "why": "network reachability — ingress/egress rules, description swaps hiding rule edits"
    },
    "aws_security_group_rule": {
      "attributes": ["*"],
      "why": "network reachability — a single rule resource IS the security decision"
    },
    "aws_vpc_security_group_ingress_rule": {
      "attributes": ["*"],
      "why": "network reachability (rule-per-resource model)"
    },
    "aws_vpc_security_group_egress_rule": {
      "attributes": ["*"],
      "why": "network reachability / exfiltration path (rule-per-resource model)"
    },
    "aws_network_acl": { "attributes": ["*"], "why": "subnet-level allow/deny" },
    "aws_network_acl_rule": { "attributes": ["*"], "why": "subnet-level allow/deny" },
    "aws_default_network_acl": { "attributes": ["*"], "why": "subnet-level allow/deny (default NACL)" },
    "aws_route": { "attributes": ["*"], "why": "traffic path — a rerouted 0.0.0.0/0 is an exfiltration/interception path" },
    "aws_route_table": { "attributes": ["route"], "why": "traffic path (inline routes)" },
    "aws_route_table_association": { "attributes": ["*"], "why": "which route table (and therefore which egress path) a subnet uses" },
    "aws_vpc_peering_connection": { "attributes": ["*"], "why": "cross-VPC trust boundary" },
    "aws_vpc_endpoint": {
      "attributes": ["policy", "private_dns_enabled", "security_group_ids", "route_table_ids", "subnet_ids"],
      "why": "endpoint policy and placement control which principals reach which AWS APIs privately"
    },
    "aws_internet_gateway": { "attributes": ["*"], "why": "internet exposure boundary" },
    "aws_subnet": { "attributes": ["map_public_ip_on_launch"], "why": "future instances become public by default" },
    "aws_iam_role": {
      "attributes": ["assume_role_policy", "permissions_boundary", "managed_policy_arns", "inline_policy*", "max_session_duration"],
      "why": "who may assume the role and what bounds it — the trust anchor for CI OIDC and instance profiles"
    },
    "aws_iam_policy": { "attributes": ["policy"], "why": "permission grants" },
    "aws_iam_role_policy": { "attributes": ["*"], "why": "inline permission grants" },
    "aws_iam_user_policy": { "attributes": ["*"], "why": "inline permission grants" },
    "aws_iam_group_policy": { "attributes": ["*"], "why": "inline permission grants" },
    "aws_iam_role_policy_attachment": { "attributes": ["*"], "why": "permission attachment" },
    "aws_iam_user_policy_attachment": { "attributes": ["*"], "why": "permission attachment" },
    "aws_iam_group_policy_attachment": { "attributes": ["*"], "why": "permission attachment" },
    "aws_iam_user": { "attributes": ["permissions_boundary"], "why": "permission bound" },
    "aws_iam_access_key": { "attributes": ["*"], "why": "long-lived credential lifecycle (status flips re-enable dormant keys)" },
    "aws_iam_instance_profile": { "attributes": ["*"], "why": "role attached to EC2 — instance privilege swap" },
    "aws_iam_openid_connect_provider": { "attributes": ["*"], "why": "federation trust anchor (CI/CD OIDC plan role rides on this)" },
    "aws_iam_saml_provider": { "attributes": ["*"], "why": "federation trust anchor" },
    "aws_s3_bucket_public_access_block": { "attributes": ["*"], "why": "the four public-access guards" },
    "aws_s3_bucket_policy": { "attributes": ["*"], "why": "bucket resource policy" },
    "aws_s3_bucket_acl": { "attributes": ["*"], "why": "bucket/object ACL grants" },
    "aws_s3_bucket_ownership_controls": { "attributes": ["*"], "why": "ACL enforcement model" },
    "aws_s3_bucket_server_side_encryption_configuration": { "attributes": ["*"], "why": "at-rest encryption posture" },
    "aws_s3_bucket_versioning": { "attributes": ["*"], "why": "data-protection posture — suspending versioning removes the recovery path" },
    "aws_s3_bucket": {
      "attributes": ["acl", "policy", "force_destroy", "object_lock*", "logging", "grant"],
      "why": "legacy inline posture attributes on the bucket resource itself"
    },
    "aws_kms_key": { "attributes": ["*"], "why": "key policy, rotation, enabled-state, deletion window — root of at-rest encryption" },
    "aws_kms_alias": { "attributes": ["*"], "why": "alias retarget silently redirects every alias-referencing encryptor" },
    "aws_cloudtrail": { "attributes": ["*"], "why": "the audit trail itself — logging toggles, selector narrowing, destination swaps" },
    "aws_config_configuration_recorder": { "attributes": ["*"], "why": "compliance recording scope" },
    "aws_config_delivery_channel": { "attributes": ["*"], "why": "compliance evidence delivery" },
    "aws_flow_log": { "attributes": ["*"], "why": "network audit visibility" },
    "aws_cloudwatch_log_group": { "attributes": ["retention_in_days", "kms_key_id"], "why": "audit-log retention shrink / encryption swap" },
    "aws_wafv2_web_acl": { "attributes": ["*"], "why": "edge protection rules and default action" },
    "aws_wafv2_ip_set": { "attributes": ["*"], "why": "WAF allow/block address material" },
    "aws_wafv2_web_acl_association": { "attributes": ["*"], "why": "detaching WAF from the ALB removes edge protection" },
    "aws_lb": {
      "attributes": ["internal", "security_groups", "enable_deletion_protection", "access_logs", "drop_invalid_header_fields", "desync_mitigation_mode"],
      "why": "load-balancer exposure + request-smuggling posture"
    },
    "aws_lb_listener": {
      "attributes": ["ssl_policy", "certificate_arn", "protocol", "port", "mutual_authentication", "alpn_policy", "default_action"],
      "why": "TLS termination posture (cert swap, protocol downgrade) and default traffic destination"
    },
    "aws_route53_record": {
      "attributes": ["records", "alias", "type", "ttl"],
      "why": "DNS answer hijack — out-of-band record edits redirect traffic"
    },
    "aws_db_instance": {
      "attributes": ["publicly_accessible", "storage_encrypted", "kms_key_id", "iam_database_authentication_enabled", "backup_retention_period", "deletion_protection", "vpc_security_group_ids", "master_username", "manage_master_user_password", "ca_cert_identifier", "monitoring_role_arn"],
      "why": "database exposure, encryption, credential and recovery posture"
    },
    "aws_efs_file_system": { "attributes": ["encrypted", "kms_key_id"], "why": "at-rest encryption of shared filesystems" },
    "aws_secretsmanager_secret": { "attributes": ["policy", "kms_key_id", "recovery_window_in_days"], "why": "secret access policy and recoverability" },
    "aws_secretsmanager_secret_rotation": { "attributes": ["*"], "why": "rotation cadence — disabling rotation is a posture change" },
    "aws_ssm_parameter": { "attributes": ["type", "key_id"], "why": "SecureString downgrade / key swap" },
    "aws_sns_topic": { "attributes": ["policy", "kms_master_key_id"], "why": "topic resource policy and encryption" },
    "aws_lambda_function": { "attributes": ["role"], "why": "function privilege swap" },
    "aws_lambda_permission": { "attributes": ["*"], "why": "function resource policy (who may invoke)" },
    "aws_lambda_function_url": { "attributes": ["*"], "why": "public invocation endpoint" },
    "aws_vpn_connection": { "attributes": ["tunnel1_preshared_key", "tunnel2_preshared_key", "remote_ipv4_network_cidr", "local_ipv4_network_cidr"], "why": "site-to-site trust material and routable scope" },
    "aws_customer_gateway": { "attributes": ["ip_address", "bgp_asn"], "why": "who the VPN peers with" },
    "aws_guardduty_detector": { "attributes": ["*"], "why": "threat-detection enablement" },
    "aws_instance": {
      "attributes": ["iam_instance_profile", "vpc_security_group_ids", "security_groups", "associate_public_ip_address", "monitoring", "metadata_options"],
      "why": "instance privilege (profile swap), reachability (SG membership), exposure (public IP), IMDS posture (metadata_options v1 re-enable)"
    }
  },
  "attribute_patterns": [
    { "pattern": "policy", "why": "resource policy = access grants (leaf 'policy' at any depth)" },
    { "pattern": "*_policy", "why": "policy-suffixed attribute (assume_role_policy, ssl_policy, queue/bucket policies)", "except_types": ["aws_dlm_lifecycle_policy"] },
    { "pattern": "policy_arn", "why": "which permission set is attached" },
    { "pattern": "kms_key_id", "why": "encryption key swap" },
    { "pattern": "kms_key_arn", "why": "encryption key swap" },
    { "pattern": "kms_master_key_id", "why": "encryption key swap" },
    { "pattern": "*encrypted*", "why": "encryption enable/disable" },
    { "pattern": "server_side_encryption*", "why": "at-rest encryption config" },
    { "pattern": "publicly_accessible", "why": "direct public exposure" },
    { "pattern": "*public_access*", "why": "public-access guardrails" },
    { "pattern": "associate_public_ip_address", "why": "public exposure" },
    { "pattern": "map_public_ip_on_launch", "why": "public-by-default subnets" },
    { "pattern": "security_groups", "why": "SG membership swap changes reachability" },
    { "pattern": "vpc_security_group_ids", "why": "SG membership swap changes reachability" },
    { "pattern": "security_group_ids", "why": "SG membership swap changes reachability" },
    { "pattern": "cidr_blocks", "why": "network scope widened/narrowed" },
    { "pattern": "ipv6_cidr_blocks", "why": "network scope widened/narrowed" },
    { "pattern": "cidr_ipv4", "why": "network scope (rule-per-resource SG model)" },
    { "pattern": "cidr_ipv6", "why": "network scope (rule-per-resource SG model)" },
    { "pattern": "source_security_group_id", "why": "rule source swap" },
    { "pattern": "ingress", "why": "inbound rules (inline SG block)" },
    { "pattern": "egress", "why": "outbound rules (inline SG block)" },
    { "pattern": "iam_instance_profile", "why": "instance privilege swap" },
    { "pattern": "permissions_boundary", "why": "permission ceiling removed/loosened" },
    { "pattern": "assume_role_policy", "why": "role trust policy" },
    { "pattern": "role_arn", "why": "privilege path swap (event targets, flow logs, integrations)" },
    { "pattern": "deletion_protection", "why": "guard against destroy removed" },
    { "pattern": "enable_deletion_protection", "why": "guard against destroy removed" },
    { "pattern": "force_destroy", "why": "data-destroying convenience flag" },
    { "pattern": "skip_final_snapshot", "why": "recovery artifact suppressed" },
    { "pattern": "backup_retention_period", "why": "recovery window shrink" },
    { "pattern": "retention_in_days", "why": "audit/log retention shrink" },
    { "pattern": "object_lock*", "why": "immutability guarantees" },
    { "pattern": "enable_logging", "why": "audit visibility toggle" },
    { "pattern": "access_logs", "why": "audit visibility toggle" },
    { "pattern": "logging_config", "why": "audit visibility toggle" },
    { "pattern": "certificate_arn", "why": "TLS identity swap" },
    { "pattern": "ssl_policy", "why": "TLS downgrade" },
    { "pattern": "metadata_options", "why": "IMDSv1 re-enable = credential-theft surface" }
  ],
  "creation_security_doctrine": "Additive key, spec docs/superpowers/specs/2026-07-20-ccp-oob-provisioning-import.md §5.3 (F-2). The lists above classify attribute CHANGES; they cannot classify a CREATION (an aws_instance row above means 'these attributes are security-posture when they change', not 'an instance is a security object'). creation_security_types is a flat list of resource types whose very CREATION out-of-band is itself the security event, regardless of which attributes it set — never portal-importable through the unmanaged-resource sweep; the front door for a legitimate emergency-created one is the manual engineer-tier kit-lane import PR (full human review of hand-curated HCL, mirroring the C2 legitimize doctrine). classify.py ignores this key (tolerant) — it is read only by the import screens (catalogctl's ClassifyFinding/ScreenCreationSecurity and their portal/API ports).",
